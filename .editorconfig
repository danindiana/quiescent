root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Nim forbids tabs for indentation.
[*.nim]
indent_style = space
indent_size = 2

[*.nimble]
indent_style = space
indent_size = 2

[*.{md,yml,yaml}]
indent_style = space
indent_size = 2

# Shell scripts in bin/ use tab indentation.
[*.sh]
indent_style = tab

[Makefile]
indent_style = tab
