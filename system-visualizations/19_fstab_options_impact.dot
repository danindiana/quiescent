
    digraph G {
        bgcolor="#0d0e15"; pad="0.4"; fontname="Courier New"; fontsize=14; fontcolor="#00ffcc";
        label="19. FSTAB MOUNT OPTION IMPACT ON PLATTER SPIN";
        node [fontname="Courier New", fontsize=9, fontcolor="#ffffff", style="filled,solid", fillcolor="#161925", color="#00d2ff", penwidth=2, shape=box];
        edge [fontname="Courier New", fontsize=8, fontcolor="#ff00cc", color="#ff00cc", penwidth=1.5];

        subgraph cluster_defaults {
            label="defaults (Read-Write)"; color="#ff5252"; fontcolor="#ff5252";
            d_mount [label="Mounted read-write"];
            d_atime [label="Writes access time (atime) updates"];
            d_shutdown [label="Forces spin-up during shutdown unmount"];
            d_mount -> d_atime -> d_shutdown;
        }

        subgraph cluster_ro_noatime {
            label="ro,noatime,nofail (Read-Only)"; color="#00ff88"; fontcolor="#00ff88";
            r_mount [label="Mounted read-only"];
            r_atime [label="No access time updates logged"];
            r_shutdown [label="Bypasses spin-up during shutdown unmount"];
            r_mount -> r_atime -> r_shutdown;
        }
    }
    